# config.env - 推理分析配置文件
# 用法: source config.env && ./run_inference.sh

# ============= 必需参数 =============
export CHECKPOINT="/home/seu/Fuxi/Unet/satellite_assimilation_v2/train_ddp/outputs/FY3F_Assimilation_physics_unet_gated_auxtrue_maskfalse_2gpu_20260128_201638/best_model.pth"
export DATA_ROOT="/data2/lrx/era_obs/npz/test"

# ============= 实验命名 =============
export EXP_NAME="physics_unet_v2_test"

# ============= 可选参数 =============
export BASELINE_CHECKPOINT="outputs/vanilla_unet/best_model.pth"
export STATS_FILE="/data2/lrx/era_obs/npz/stats.npz"

# ============= 运行参数 =============
export BATCH_SIZE=32
export NUM_WORKERS=8
export DEVICE="cuda"

# ============= 可视化参数 =============
export CASE_STUDY_IDX=5
export LEVEL_IDX=15

# ============= 地理范围（中国区域）=============
export LON_MIN=70
export LON_MAX=140
export LAT_MIN=15
export LAT_MAX=55

# ============= 其他选项 =============
export COMPRESS=true
